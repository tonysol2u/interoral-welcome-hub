# ═══════════════════════════════════════════════════════
# INTERORAL WELCOME HUB — Environment Configuration
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════════

# Server
PORT=3001
NODE_ENV=production

# Database (Postgres on EC2 or RDS)
DATABASE_URL=postgresql://user:password@localhost:5432/interoral_gateway

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# GHL (GoHighLevel)
GHL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/...

# Relu.ai
RELU_API_KEY=...
RELU_BASE_URL=https://api.relu.ai

# AWS S3
AWS_S3_BUCKET=interoral-scans
AWS_REGION=us-east-1

# Resend (for transactional emails)
RESEND_API_KEY=re_...

# Security
JWT_SECRET=your-jwt-secret-here
CORS_ORIGIN=https://mastercrown.ai,https://masterstl.ai
